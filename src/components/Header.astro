<style is:global>
  @media (max-width: 980px) {
    /* High-specificity rule to hide sub-menus in mobile */
    body #main-header #top-menu-nav #top-menu li.menu-item-has-children .sub-menu,
    body .et_mobile_menu li.menu-item-has-children .sub-menu {
      display: none !important;
    }
    body #main-header #top-menu-nav #top-menu li.menu-item-has-children.open > .sub-menu,
    body .et_mobile_menu li.menu-item-has-children.open > .sub-menu {
      display: block !important;
    }
    .menu-item-has-children > a::after { content: ' ▾'; font-size:10px; opacity:.6; }
    .menu-item-has-children.open > a::after { content: ' ▴'; }
  }
</style>

<script is:inline>
(function () {
  function forceCloseAll(root) {
    (root || document).querySelectorAll('.menu-item-has-children').forEach(function (item) {
      item.classList.remove('open');
      var sub = item.querySelector('.sub-menu');
      if (sub) sub.style.setProperty('display', 'none', 'important');
    });
  }

  /* Event delegation — works on Divi-cloned mobile menu too */
  document.addEventListener('click', function (e) {
    if (window.innerWidth > 980) return;

    /* Hamburger click: force-close all sub-menus after Divi opens the panel */
    if (e.target.closest && e.target.closest('.mobile_menu_bar')) {
      setTimeout(forceCloseAll, 80);
      return;
    }

    /* Parent nav-link click: toggle sub-menu */
    var link = e.target.closest && e.target.closest('.menu-item-has-children > a');
    if (!link) return;
    e.preventDefault();
    e.stopImmediatePropagation();
    var parent = link.parentElement;
    var sub    = parent.querySelector('.sub-menu');
    var isOpen = parent.classList.contains('open');

    /* Close siblings */
    if (parent.parentElement) {
      parent.parentElement.querySelectorAll('.menu-item-has-children').forEach(function (s) {
        s.classList.remove('open');
        var ss = s.querySelector('.sub-menu');
        if (ss) ss.style.setProperty('display', 'none', 'important');
      });
    }

    /* Toggle current */
    if (!isOpen && sub) {
      parent.classList.add('open');
      sub.style.setProperty('display', 'block', 'important');
    }
  });

  /* Watch for Divi dynamically inserting .et_mobile_menu */
  new MutationObserver(function (mutations) {
    if (window.innerWidth > 980) return;
    mutations.forEach(function (m) {
      m.addedNodes.forEach(function (node) {
        if (node.nodeType !== 1) return;
        if (node.classList.contains('et_mobile_menu') || node.querySelector && node.querySelector('.et_mobile_menu')) {
          setTimeout(forceCloseAll, 50);
        }
      });
    });
  }).observe(document.documentElement, { childList: true, subtree: true });

  /* Reset on resize to desktop */
  window.addEventListener('resize', function () {
    if (window.innerWidth > 980) {
      document.querySelectorAll('.menu-item-has-children').forEach(function (el) {
        el.classList.remove('open');
        var sub = el.querySelector('.sub-menu');
        if (sub) sub.style.removeProperty('display');
      });
    }
  });
})();
</script>

