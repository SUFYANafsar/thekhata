<script is:inline>
(function () {
  var btn   = document.getElementById('sa-wa-btn');
  var popup = document.getElementById('sa-wa-popup');
  var close = document.getElementById('sa-close-btn');

  function openPopup()  { popup.classList.add('sa-open'); }
  function closePopup() { popup.classList.remove('sa-open'); }
  function togglePopup(){ popup.classList.toggle('sa-open'); }

  btn.addEventListener('click', togglePopup);
  close.addEventListener('click', function(e){ e.stopPropagation(); closePopup(); });

  document.addEventListener('click', function(e){
    if (!popup.contains(e.target) && !btn.contains(e.target)) closePopup();
  });

  window.saSendWA = function(msg){
    window.open('https://wa.me/923111006555?text=' + encodeURIComponent(msg), '_blank');
  };

  setTimeout(openPopup, 1500);
})();
</script>
