<style>
.sp-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.72);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 999999;
}

.sp-box {
  width: 360px;
  border-radius: 18px;
  overflow: hidden;
  box-shadow: 0 24px 64px rgba(0,0,0,0.45);
  animation: sp-rise 0.3s cubic-bezier(.22,.61,.36,1) both;
}
@keyframes sp-rise {
  from { opacity:0; transform:translateY(24px); }
  to   { opacity:1; transform:translateY(0); }
}

/* ── Header ── */
.sp-header {
  background: #0d1b35;
  padding: 20px 20px 16px;
  position: relative;
}
.sp-close {
  position: absolute;
  top: 12px; right: 14px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  width: 26px; height: 26px;
  border-radius: 50%;
  font-size: 16px; line-height: 1;
  color: #fff;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background .2s;
}
.sp-close:hover { background: rgba(255,255,255,0.25); }

.sp-avatars { display:flex; margin-bottom:12px; }
.sp-avatars img {
  width: 40px; height: 40px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid #1a3461;
  margin-right: -8px;
}
.sp-avatars img:last-child { margin-right: 0; }

.sp-online {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(37,211,102,0.15);
  border: 1px solid rgba(37,211,102,0.35);
  border-radius: 20px;
  padding: 3px 10px;
  font-size: 11px;
  font-weight: 600;
  color: #4dffa0;
  margin-bottom: 10px;
  letter-spacing: .03em;
}
.sp-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #25D366;
  flex-shrink: 0;
  animation: sp-pulse 1.8s infinite;
}
@keyframes sp-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(37,211,102,.6); }
  70%  { box-shadow: 0 0 0 5px rgba(37,211,102,0); }
  100% { box-shadow: 0 0 0 0 rgba(37,211,102,0); }
}
.sp-header h2 {
  font-size: 18px; font-weight: 800;
  color: #fff; margin: 0 0 4px; line-height: 1.3;
}
.sp-header p { font-size: 12px; color: rgba(255,255,255,.65); margin: 0; }

/* ── Body ── */
.sp-body {
  background: #fff;
  padding: 18px 18px 20px;
}
.sp-bubble {
  background: #f0f7ff;
  border-left: 3px solid #2ea3f2;
  border-radius: 8px;
  padding: 10px 12px;
  font-size: 13px;
  color: #1a2b4a;
  line-height: 1.55;
  margin-bottom: 14px;
}
.sp-options {
  display: flex;
  flex-direction: column;
  gap: 7px;
  margin-bottom: 16px;
}
.sp-option {
  display: flex;
  align-items: center;
  gap: 9px;
  background: #f7faff;
  border: 1.5px solid #dce8f5;
  border-radius: 9px;
  padding: 9px 12px;
  font-size: 13px;
  font-weight: 500;
  color: #1a2b4a;
  text-decoration: none;
  transition: all .18s;
}
.sp-option:hover {
  background: #e4f2ff;
  border-color: #2ea3f2;
  color: #1565a8;
}
.sp-option span:first-child { font-size: 15px; }

.sp-actions { display: flex; gap: 9px; }
.sp-btn-wa {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 11px 16px;
  border: none;
  border-radius: 9px;
  background: #25D366;
  color: #fff !important;
  font-size: 13px;
  font-weight: 700;
  text-decoration: none !important;
  cursor: pointer;
  transition: background .2s;
}
.sp-btn-wa:hover { background: #1da851; }
.sp-btn-skip {
  padding: 11px 16px;
  border: 1.5px solid #dce8f5;
  border-radius: 9px;
  background: #fff;
  color: #6b7a90;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  transition: all .18s;
}
.sp-btn-skip:hover { background: #f7faff; color: #1a2b4a; }

@media (max-width: 420px) {
  .sp-box { width: 92vw; }
}
</style>

