<style>
/* ── Overlay ── */
.sp-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10,20,40,0.65);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 999999;
  backdrop-filter: blur(3px);
  -webkit-backdrop-filter: blur(3px);
}

/* ── Box ── */
.sp-box {
  position: relative;
  width: 380px;
  border-radius: 20px;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 30px 80px rgba(0,0,0,0.30);
  animation: sp-rise 0.35s cubic-bezier(.22,.61,.36,1) both;
}
@keyframes sp-rise {
  from { opacity:0; transform: translateY(28px) scale(.97); }
  to   { opacity:1; transform: translateY(0)   scale(1);    }
}

/* ── Header band ── */
.sp-header {
  background: linear-gradient(135deg, #0d1b35 0%, #1a3461 55%, #1565a8 100%);
  padding: 26px 24px 20px;
  position: relative;
}
.sp-header::after {
  content: '';
  position: absolute;
  width: 220px; height: 220px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(46,163,242,.22) 0%, transparent 70%);
  top: -60px; right: -60px;
  pointer-events: none;
}

/* close btn */
.sp-close {
  position: absolute;
  top: 12px; right: 14px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.22);
  width: 28px; height: 28px;
  border-radius: 50%;
  font-size: 18px; line-height: 1;
  color: #fff;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background .2s;
  z-index: 3;
}
.sp-close:hover { background: rgba(255,255,255,0.25); }

/* avatar stack */
.sp-avatars {
  display: flex;
  margin-bottom: 14px;
}
.sp-avatars img {
  width: 44px; height: 44px;
  border-radius: 50%;
  object-fit: cover;
  border: 2.5px solid rgba(255,255,255,0.6);
  margin-right: -10px;
  box-shadow: 0 3px 10px rgba(0,0,0,0.25);
}
.sp-avatars img:last-child { margin-right: 0; }

/* online badge */
.sp-online {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(37,211,102,0.18);
  border: 1px solid rgba(37,211,102,0.4);
  border-radius: 20px;
  padding: 3px 10px;
  font-size: 11px;
  font-weight: 600;
  color: #4dffa0;
  margin-bottom: 10px;
  letter-spacing: .04em;
}
.sp-online-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #25D366;
  animation: sp-pulse 1.8s infinite;
  flex-shrink: 0;
}
@keyframes sp-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(37,211,102,0.7); }
  70%  { box-shadow: 0 0 0 5px rgba(37,211,102,0); }
  100% { box-shadow: 0 0 0 0 rgba(37,211,102,0); }
}

.sp-header h2 {
  font-size: 20px;
  font-weight: 800;
  color: #fff;
  margin: 0 0 6px;
  line-height: 1.25;
}
.sp-header-sub {
  font-size: 13px;
  color: rgba(255,255,255,0.75);
  line-height: 1.5;
  margin: 0;
}

/* ── Body ── */
.sp-body {
  padding: 20px 24px 24px;
  background: #fff;
}

/* chat bubble */
.sp-bubble {
  background: #f0f7ff;
  border: 1px solid #d0e8ff;
  border-radius: 0 14px 14px 14px;
  padding: 12px 14px;
  font-size: 13px;
  color: #1a2b4a;
  line-height: 1.6;
  margin-bottom: 16px;
  position: relative;
}
.sp-bubble::before {
  content: '';
  position: absolute;
  top: 0; left: -8px;
  border-width: 0 8px 8px 0;
  border-style: solid;
  border-color: transparent #d0e8ff transparent transparent;
}

/* quick options */
.sp-options {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 18px;
}
.sp-option {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #f7faff;
  border: 1.5px solid #e0eaf5;
  border-radius: 10px;
  padding: 9px 14px;
  font-size: 13px;
  font-weight: 500;
  color: #1a2b4a;
  cursor: pointer;
  text-decoration: none;
  transition: all .2s;
}
.sp-option:hover {
  background: #e8f5ff;
  border-color: #2ea3f2;
  color: #1a78c2;
  transform: translateX(3px);
}
.sp-option-icon { font-size: 16px; flex-shrink: 0; }

/* CTA row */
.sp-actions {
  display: flex;
  gap: 10px;
}
.sp-btn-primary {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  padding: 12px 18px;
  border: none;
  border-radius: 10px;
  background: linear-gradient(135deg, #25D366, #1da851);
  color: #fff !important;
  font-size: 14px;
  font-weight: 700;
  text-decoration: none !important;
  cursor: pointer;
  box-shadow: 0 6px 20px rgba(37,211,102,0.35);
  transition: all .2s;
}
.sp-btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 28px rgba(37,211,102,0.45);
  color: #fff !important;
}
.sp-btn-secondary {
  padding: 12px 18px;
  border: 1.5px solid #e0eaf5;
  border-radius: 10px;
  background: #fff;
  color: #5a6a80;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: all .2s;
  white-space: nowrap;
}
.sp-btn-secondary:hover {
  background: #f7faff;
  border-color: #c0d0e0;
  color: #1a2b4a;
}

@media (max-width: 440px) {
  .sp-box { width: 92vw; }
}
</style>

