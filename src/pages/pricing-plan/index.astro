<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Splendid Accounts Blue Pricing Plans</title>
<style>
  :root {
    --sa-blue-light: #65BFEB;
    --sa-blue-dark: #4fa8d6;
    --sa-text-dark: #222;
    --sa-bg-light: #f5f8f7;
    --sa-gray-light: #f7f7f7;
    --sa-gray-medium: #ededed;
  }

  .sa-blue-body {
    background: var(--sa-bg-light);
    margin: 0;
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: "Segoe UI", Arial, sans-serif;
  }

  .sa-blue-pricing-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 25px;
    width: 100%;
    max-width: 420px;
  }

  .sa-blue-plan-card {
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
    padding: 25px 20px;
    width: 100%;
    text-align: center;
    transition: all 0.3s ease;
    overflow: hidden;
    border-top: 5px solid var(--sa-blue-light);
  }

  .sa-blue-plan-card:hover {
    transform: scale(1.02);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  .sa-blue-plan-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--sa-text-dark);
    margin-bottom: 10px;
    text-transform: uppercase;
  }

  .sa-blue-plan-price {
    font-size: 34px;
    font-weight: 800;
    color: var(--sa-blue-dark);
    margin: 10px 0;
  }

  .sa-blue-plan-price sup {
    font-size: 15px;
    top: -8px;
    position: relative;
  }

  .sa-blue-plan-duration {
    font-size: 15px;
    color: #666;
    margin-bottom: 15px;
  }

  .sa-blue-select-btn {
    display: inline-block;
    background: linear-gradient(135deg, var(--sa-blue-light), var(--sa-blue-dark));
    color: #fff;
    font-weight: 600;
    text-decoration: none;
    border-radius: 30px;
    padding: 12px 30px;
    transition: all 0.3s ease;
    margin-top: 10px;
  }

  .sa-blue-select-btn:hover {
    background: linear-gradient(135deg, var(--sa-blue-dark), var(--sa-blue-light));
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(47, 124, 194, 0.3);
  }

  .sa-blue-features-toggle {
    color: var(--sa-blue-dark);
    font-weight: 600;
    cursor: pointer;
    display: inline-block;
    margin-top: 12px;
    transition: all 0.3s ease;
  }

  .sa-blue-features-toggle:hover {
    color: var(--sa-blue-light);
  }

  .sa-blue-features {
    display: none;
    margin-top: 15px;
    text-align: left;
    font-size: 14px;
    color: #333;
    background: #f9faf9;
    border-radius: 12px;
    overflow: hidden;
    animation: sa-blue-fadeIn 0.4s ease;
  }

  /* Table-style features */
  .sa-blue-features-table {
    width: 100%;
    border-collapse: collapse;
  }

  .sa-blue-features-table tr:nth-child(odd) {
    background: var(--sa-gray-light);
  }

  .sa-blue-features-table tr:nth-child(even) {
    background: var(--sa-gray-medium);
  }

  .sa-blue-features-table td {
    padding: 10px 15px;
    border: none;
  }

  .sa-blue-features-table td::before {
    content: "✔ ";
    color: var(--sa-blue-dark);
    font-weight: bold;
    margin-right: 5px;
  }

  @keyframes sa-blue-fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 480px) {
    .sa-blue-plan-card {
      padding: 20px 15px;
    }
    .sa-blue-plan-title {
      font-size: 19px;
    }
    .sa-blue-plan-price {
      font-size: 28px;
    }
    .sa-blue-features-table td {
      font-size: 13px;
      padding: 8px 10px;
    }
  }
</style>
</head>
