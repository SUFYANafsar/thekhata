<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Splendid Accounts Pricing Plans</title>
<style>
  :root {
    --green-light: #00c853;
    --green-dark: #00a74f;
    --text-dark: #222;
    --bg-light: #f5f8f7;
    --gray-light: #f2f2f2;
  }

  body {
    background: var(--bg-light);
    margin: 0;
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: "Segoe UI", Arial, sans-serif;
  }

  h2 {
    color: var(--green-dark);
    text-align: center;
    font-size: 24px;
    margin-bottom: 25px;
    letter-spacing: 0.5px;
  }

  .pricing-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 25px;
    width: 100%;
    max-width: 420px;
  }

  .plan-card {
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
    padding: 25px 20px;
    width: 100%;
    text-align: center;
    transition: all 0.3s ease;
    overflow: hidden;
    border-top: 5px solid var(--green-light);
  }

  .plan-card:hover {
    transform: scale(1.02);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  .plan-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 10px;
    text-transform: uppercase;
  }

  .plan-price {
    font-size: 40px;
    font-weight: 800;
    color: var(--green-dark);
    margin: 10px 0;
  }

  .plan-price sup {
    font-size: 15px;
    top: -8px;
    position: relative;
  }

  .plan-duration {
    font-size: 15px;
    color: #666;
    margin-bottom: 15px;
  }

  .button s {
    display: block;
    color: #777;
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 6px;
    text-decoration: line-through;
  }

  .select-btn {
    display: inline-block;
    background: linear-gradient(135deg, var(--green-light), var(--green-dark));
    color: #fff;
    font-weight: 600;
    text-decoration: none;
    border-radius: 30px;
    padding: 12px 30px;
    transition: all 0.3s ease;
    margin-top: 10px;
  }

  .select-btn:hover {
    background: linear-gradient(135deg, var(--green-dark), var(--green-light));
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 160, 80, 0.3);
  }

  .features-toggle {
    color: var(--green-dark);
    font-weight: 600;
    cursor: pointer;
    display: inline-block;
    margin-top: 12px;
    transition: all 0.3s ease;
  }

  .features-toggle:hover {
    color: var(--green-light);
  }

  .features {
    display: none;
    margin-top: 15px;
    text-align: left;
    font-size: 14px;
    color: #333;
    border-radius: 12px;
    overflow: hidden;
    animation: fadeIn 0.4s ease;
  }

  /* ✅ Scoped green check marks */
  .features table td::before {
    content: "✔ ";
    color: var(--green-dark);
    font-weight: bold;
    margin-right: 6px;
  }

  .features table {
    width: 100%;
    border-collapse: collapse;
  }

  .features tr:nth-child(odd) {
    background-color: #fff;
  }

  .features tr:nth-child(even) {
    background-color: var(--gray-light);
  }

  .features td {
    padding: 10px 15px;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 480px) {
    .plan-card {
      padding: 20px 15px;
    }
    .plan-title {
      font-size: 19px;
    }
    .plan-price {
      font-size: 28px;
    }
  }
</style>
</head>
