<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pricing Card - Branch</title>
  <style>
    * {
      box-sizing: border-box;
    }

    .branch-container {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 40px 0;
    }

    .branch-card {
      width: 320px;
