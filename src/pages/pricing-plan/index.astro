<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stylish Pricing Table - Blue Theme</title>
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      margin: 0;
      padding: 40px;
      background: #f4f7f6;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    /* ===================== BLUE THEME ===================== */
    .pricing-blue table {
      width: 95%;
      max-width: 1200px;
      border-collapse: collapse;
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
      border-radius: 12px;
      overflow: hidden;
      background: #fff;
      text-align: center;
    }

    /* Table Header */
    .pricing-blue th {
      background: #65BFEB;
      color: white !important;
      padding: 20px;
      font-size: 18px;
      text-transform: uppercase;
      text-align: center;
      text-shadow: 1px 1px 2px rgba(0,0,0,0.2); /* ✅ Text shadow */
    }

    .pricing-blue th * {
      color: white !important;
    }

    .pricing-blue th:nth-child(2) {
      background: #4AAEE0; /* lighter shade */
    }

    .pricing-blue th.highlight {
      background: #3099D6; /* darker shade */
      font-size: 20px;
    }

    /* Table Cells */
    .pricing-blue td {
      padding: 14px;
      border: 1px solid #e6e6e6;
      font-size: 14px;
      color: #333;
      text-align: center;
      text-shadow: 1px 1px 2px rgba(0,0,0,0.1); /* ✅ Text shadow */
    }

    .pricing-blue td strong {
      font-size: 16px;
      color: #3099D6;
    }

    /* Bold left column features */
    .pricing-blue td:first-child {
      font-weight: bold;
      text-align: left;
      text-shadow: none; /* ✅ Keep feature text clean */
    }

    .pricing-blue .check {
      color: #3099D6;
      font-size: 18px;
      font-weight: bold;
    }

    .pricing-blue .cross {
      color: #e74c3c;
      font-weight: bold;
    }

    .pricing-blue tr:nth-child(even) {
      background: #f9fcff; /* subtle blue background */
    }

    /* Hover effect */
    .pricing-blue th:hover  {
      color: black;
          background: rgba(48, 25, 52);
      transition: 0.3s;
    }
    .pricing-blue td:hover {
      background: rgba(101, 191, 235, 0.12);
      transition: 0.3s;
    }

    /* CTA Button */
    .pricing-blue .btn {
      display: inline-block;
      padding: 12px 30px;
      min-width: 160px; /* ✅ Increased button width */
      background: #65BFEB;
      color: #fff;
      border-radius: 25px;
      text-decoration: none;
      font-weight: bold;
      text-align: center;
      transition: 0.3s;
      text-shadow: 1px 1px 2px rgba(0,0,0,0.3); /* ✅ Text shadow on button */
    }

    .pricing-blue .btn:hover {
      background: #3099D6;
    }
  </style>
</head>
