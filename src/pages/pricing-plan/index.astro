<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pricing Card - Order Booker</title>
  <style>
    * {
      box-sizing: border-box;
    }

    .order-container {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 40px 0;
    }

    .order-card {
      width: 320px;
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
      overflow: hidden;
      text-align: center;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      margin: 10px;
      cursor: pointer;
    }

    .order-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 18px 45px rgba(101, 191, 235, 0.4);
    }

    .order-header {
      background: #65BFEB;
      padding: 18px;
      color: #fff;
      font-weight: bold;
      font-size: 20px;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .order-title {
      color: #000;
      font-size: 26px;
      margin: 15px 0 10px;
      transition: color 0.3s ease;
      font-weight: bold;
    }

    .order-features {
      background: #65BFEB;
      color: #fff;
      font-weight: 600;
      padding: 8px;
      font-size: 15px;
    }

    .order-price {
      margin-top: 20px;
      font-size: 34px;
      font-weight: bold;
      color: #222;
      transition: transform 0.3s ease, color 0.3s ease;
    }

    .order-price span {
      font-size: 15px;
      color: #888;
      display: block;
    }

    .order-button {
      display: inline-block;
      background: #65BFEB;
      color: #fff;
      padding: 10px 28px;
      border-radius: 30px;
      text-decoration: none;
      font-weight: 600;
      margin: 18px 0 8px;
      transition: all 0.3s ease;
    }

    .order-button:hover {
      background: #4aa7d6;
      box-shadow: 0 5px 15px rgba(101, 191, 235, 0.4);
    }
  </style>
</head>
<body>

<section class="order-container">
  <div class="order-card" id="orderCard">
    <div class="order-header">Pay For</div>
    <div class="order-title" >Order Booker</div>

    <div class="order-features">Mobile Application</div>

    <div class="order-price" >
      <sup><b style="font-size: 12px;">PKR</b></sup> 
      <b style="font-size: 34px;">1,030/mo</b>
      <span>(incl. Sales Tax)</span>
    </div>

    <a href="/../free-trial/" class="order-button">Buy Now</a>
  </div>
</section>

<script>
  var card = document.getElementById('orderCard');
  var price = document.getElementById('orderPrice');
  var text = document.getElementById('orderText');

  card.addEventListener('mouseenter', () => {
    price.style.transform = 'scale(1.12)';
    price.style.color = '#65BFEB';
    text.style.color = '#65BFEB';
  });

  card.addEventListener('mouseleave', () => {
    price.style.transform = 'scale(1)';
    price.style.color = '#222';
    text.style.color = '#000';
  });

  card.addEventListener('click', () => {
    window.location.href = '../free-trial/index.html';
  });
