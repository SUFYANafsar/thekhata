  <!-- Toggle Script -->
  <script is:inline>
    var toggle = document.getElementById('plan-toggle');
    var yearly = document.getElementById('yearly-plans');
    var monthly = document.getElementById('monthly-plans');
    var lblY = document.getElementById('lbl-yearly');
    var lblM = document.getElementById('lbl-monthly');
    if (toggle) {
      toggle.addEventListener('change', function() {
        if (this.checked) {
          yearly.style.display = 'none';
          monthly.style.display = 'grid';
          lblY.classList.remove('active');
          lblM.classList.add('active');
        } else {
          yearly.style.display = 'grid';
          monthly.style.display = 'none';
          lblY.classList.add('active');
          lblM.classList.remove('active');
        }
      });
    }
  </script>
