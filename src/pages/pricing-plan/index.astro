<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pricing Card - Digital Invoicing</title>
  <style>
    * {
      box-sizing: border-box;
    }

    .pricing-container-digitalinvoicing {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 40px 0;
    }

    .pricing-card-digitalinvoicing {
      width: 320px;
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
      overflow: hidden;
      text-align: center;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      position: relative;
      margin: 10px;
      cursor: pointer;
    }

    .pricing-card-digitalinvoicing:hover {
      transform: translateY(-8px);
      box-shadow: 0 18px 45px rgba(0, 160, 80, 0.2);
    }

    .pricing-header-digitalinvoicing {
      background: linear-gradient(135deg, #00d35f, #009d47);
      padding: 18px;
      color: #fff;
      font-weight: bold;
      font-size: 20px;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .pricing-user-digitalinvoicing {
      color: #000;
      font-size: 26px;
      margin: 15px 0 10px;
      transition: color 0.3s ease;
      font-weight: bold;
    }

    .pricing-features-digitalinvoicing {
      background: #00b04f;
      color: #fff;
      font-weight: 600;
      padding: 8px;
      font-size: 15px;
    }

    .pricing-amount-digitalinvoicing {
      margin-top: 20px;
      font-size: 34px;
      font-weight: bold;
      color: #222;
      transition: transform 0.3s ease, color 0.3s ease;
    }

    .pricing-amount-digitalinvoicing span {
      font-size: 15px;
      color: #888;
      display: block;
    }

    .pricing-btn-digitalinvoicing {
      display: inline-block;
      background: linear-gradient(135deg, #00c853, #00a74f);
      color: #fff;
      padding: 10px 28px;
      border-radius: 30px;
      text-decoration: none;
      font-weight: 600;
      margin: 18px 0 8px;
      transition: all 0.3s ease;
    }

    .pricing-btn-digitalinvoicing:hover {
      background: #00a04a;
      box-shadow: 0 5px 15px rgba(0, 160, 80, 0.3);
    }
  </style>
</head>
<body>

<section class="pricing-container-digitalinvoicing">
  <div class="pricing-card-digitalinvoicing" id="digitalInvoicingCard">
    <div class="pricing-header-digitalinvoicing">Pay For</div>
    <div class="pricing-user-digitalinvoicing" id="digitalInvoicingText">Digital Invoicing</div>

    <div class="pricing-features-digitalinvoicing">All Features Included</div>

    <div class="pricing-amount-digitalinvoicing" id="digitalInvoicingPrice">
      <sup><b style="font-size: 12px;">PKR</b></sup> 
      <b style="font-size: 34px;">1,500/mo</b>
      <span>(incl. Sales Tax)</span>
    </div>

    <a href="/../free-trial/" class="pricing-btn-digitalinvoicing">Buy Now</a>
  </div>
</section>

<script>
  var card = document.getElementById('digitalInvoicingCard');
  var price = document.getElementById('digitalInvoicingPrice');
  var text = document.getElementById('digitalInvoicingText');

  card.addEventListener('mouseenter', () => {
    price.style.transform = 'scale(1.12)';
    price.style.color = '#00a74f';
    text.style.color = '#00a74f';
  });

  card.addEventListener('mouseleave', () => {
    price.style.transform = 'scale(1)';
    price.style.color = '#222';
    text.style.color = '#000';
  });

  card.addEventListener('click', () => {
    window.location.href = '../free-trial/index.html';
  });
</script>

