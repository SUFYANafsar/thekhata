---
import PageLayout from '../../layouts/PageLayout.astro'
---
<PageLayout
  title="Pricing Plan - FBR Software"
  description="Simple, transparent pricing for every business size. Start your 14-day free trial today — no credit card required."
  canonical="/pricing-plan/"
  ogImage="/wp-content/uploads/2022/01/link-image.jpg"
  bodyClass="fbr-home"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/pages/__home__-redesign.css" />
    <style>
      /* ── Pricing page extras ── */
      .fbr-pricing-hero {
        background: linear-gradient(135deg,#0d1b35 0%,#1a3461 50%,#1565a8 100%);
        padding: 80px 20px 60px;
        text-align: center;
        color: #fff;
      }
      .fbr-pricing-hero h1 { font-size:clamp(28px,4vw,48px); font-weight:800; margin:0 0 14px; }
      .fbr-pricing-hero p  { font-size:17px; color:rgba(255,255,255,.75); max-width:560px; margin:0 auto; }

      /* toggle */
      .fbr-toggle-wrap {
        display:flex; align-items:center; justify-content:center; gap:16px;
        padding:36px 20px 0;
      }
      .fbr-toggle-label {
        font-size:16px; font-weight:700; color:#1a2b4a;
        transition:color .2s;
      }
      .fbr-toggle-label.active { color:#2ea3f2; }
      .fbr-toggle-label .save-badge {
        display:inline-block;
        background:#e8fff2; color:#00a74f;
        font-size:11px; font-weight:700;
        padding:2px 8px; border-radius:10px;
        margin-left:6px;
      }
      .fbr-switch {
        position:relative; display:inline-block;
        width:56px; height:30px; cursor:pointer;
      }
      .fbr-switch input { opacity:0; width:0; height:0; }
      .fbr-switch-slider {
        position:absolute; inset:0;
        background:#2ea3f2; border-radius:30px;
        transition:.35s;
      }
      .fbr-switch-slider:before {
        content:''; position:absolute;
        width:22px; height:22px;
        left:4px; top:4px;
        background:#fff; border-radius:50%;
        transition:.35s;
        box-shadow:0 2px 6px rgba(0,0,0,.15);
      }
      .fbr-switch input:checked + .fbr-switch-slider { background:#1a78c2; }
      .fbr-switch input:checked + .fbr-switch-slider:before { transform:translateX(26px); }

      /* plans grid */
      .fbr-plans-wrap { max-width:1200px; margin:0 auto; padding:48px 20px 0; }
      .fbr-plans-grid {
        display:grid;
        grid-template-columns:repeat(4,1fr);
        gap:24px;
      }
      .fbr-plan-card {
        background:#fff;
        border-radius:20px;
        box-shadow:0 4px 24px rgba(26,43,74,.08);
        overflow:hidden;
        display:flex; flex-direction:column;
        transition:transform .25s, box-shadow .25s;
        border:2px solid transparent;
      }
      .fbr-plan-card:hover {
        transform:translateY(-8px);
        box-shadow:0 16px 48px rgba(46,163,242,.18);
        border-color:#2ea3f2;
      }
      .fbr-plan-card.featured {
        border-color:#2ea3f2;
        position:relative;
      }
      .fbr-popular-badge {
        position:absolute; top:-1px; left:50%; transform:translateX(-50%);
        background:#2ea3f2; color:#fff;
        font-size:11px; font-weight:700; letter-spacing:.06em;
        padding:4px 14px; border-radius:0 0 10px 10px;
        white-space:nowrap;
      }
      .fbr-plan-header {
        padding:28px 24px 20px;
        text-align:center;
        border-bottom:1px solid #f0f4f8;
      }
      .fbr-plan-name {
        font-size:13px; font-weight:700; letter-spacing:.1em;
        text-transform:uppercase; color:#5a6a80; margin-bottom:14px;
      }
      .fbr-plan-price-wrap { margin-bottom:6px; }
      .fbr-plan-old-price {
        font-size:15px; color:#aab; text-decoration:line-through;
        display:block; min-height:20px; margin-bottom:2px;
      }
      .fbr-plan-price {
        font-size:38px; font-weight:800; color:#1a2b4a;
        line-height:1;
      }
      .fbr-plan-price sup { font-size:14px; font-weight:600; vertical-align:top; margin-top:8px; display:inline-block; }
      .fbr-plan-period { font-size:13px; color:#5a6a80; margin-top:4px; }
      .fbr-plan-discount {
        display:inline-block; background:#e8fff2; color:#00a74f;
        font-size:12px; font-weight:700; padding:3px 10px;
        border-radius:10px; margin-top:8px;
      }
      .fbr-plan-body { padding:20px 24px; flex:1; }
      .fbr-plan-module {
        background:#f0f8ff; color:#1a78c2;
        font-size:13px; font-weight:700;
        padding:6px 12px; border-radius:8px;
        margin-bottom:16px; text-align:center;
      }
      .fbr-plan-features { list-style:none; padding:0; margin:0; }
      .fbr-plan-features li {
        font-size:13px; color:#3a4a60;
        padding:7px 0; border-bottom:1px solid #f0f4f8;
        display:flex; align-items:center; gap:8px;
      }
      .fbr-plan-features li:last-child { border-bottom:none; }
      .fbr-plan-features .yes { color:#2ea3f2; font-weight:700; flex-shrink:0; }
      .fbr-plan-features .no  { color:#d0d8e4; font-weight:700; flex-shrink:0; }
      .fbr-plan-footer { padding:20px 24px 28px; text-align:center; }
      .fbr-plan-cta {
        display:block; width:100%;
        padding:13px 20px; border-radius:10px;
        font-size:14px; font-weight:700;
        text-decoration:none; text-align:center;
        background:linear-gradient(135deg,#2ea3f2,#1a78c2);
        color:#fff;
        box-shadow:0 4px 14px rgba(46,163,242,.3);
        transition:all .25s;
      }
      .fbr-plan-cta:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(46,163,242,.4); }
      .fbr-plan-cta.outline {
        background:transparent; color:#2ea3f2;
        border:2px solid #2ea3f2; box-shadow:none;
      }
      .fbr-plan-cta.outline:hover { background:#2ea3f2; color:#fff; }

      /* note */
      .fbr-pricing-note {
        text-align:center; font-size:13px; color:#8090a8;
        padding:20px 20px 0; max-width:1200px; margin:0 auto;
      }

      /* addons */
      .fbr-addons-section { background:#f7faff; }
      .fbr-addons-grid {
        display:grid;
        grid-template-columns:repeat(4,1fr);
        gap:24px; margin-top:40px;
      }
      .fbr-addon-card {
        background:#fff; border-radius:16px;
        overflow:hidden;
        box-shadow:0 4px 20px rgba(26,43,74,.07);
        text-align:center;
        transition:transform .25s, box-shadow .25s;
        cursor:pointer;
      }
      .fbr-addon-card:hover {
        transform:translateY(-6px);
        box-shadow:0 12px 36px rgba(46,163,242,.15);
      }
      .fbr-addon-header {
        background:linear-gradient(135deg,#2ea3f2,#1a78c2);
        padding:14px 20px;
        color:#fff; font-size:11px;
        font-weight:700; letter-spacing:.1em;
        text-transform:uppercase;
      }
      .fbr-addon-name { font-size:20px; font-weight:700; color:#1a2b4a; padding:16px 16px 4px; }
      .fbr-addon-type {
        background:#e8f5ff; color:#1a78c2;
        font-size:12px; font-weight:600;
        padding:5px 0; margin:0 16px 4px;
        border-radius:6px;
      }
      .fbr-addon-price {
        font-size:30px; font-weight:800; color:#1a2b4a;
        padding:12px 16px 4px;
      }
      .fbr-addon-price sup { font-size:12px; vertical-align:top; margin-top:6px; display:inline-block; }
      .fbr-addon-incl { font-size:12px; color:#8090a8; padding-bottom:4px; }
      .fbr-addon-btn {
        display:inline-block;
        background:linear-gradient(135deg,#2ea3f2,#1a78c2);
        color:#fff; font-weight:600;
        padding:10px 28px; border-radius:30px;
        text-decoration:none; margin:14px 0 20px;
        font-size:13px;
        transition:all .25s;
      }
      .fbr-addon-btn:hover { transform:translateY(-2px); box-shadow:0 6px 18px rgba(46,163,242,.35); }

      /* contact */
      .fbr-pricing-contact {
        background:linear-gradient(135deg,#0d1b35,#1a3461);
        padding:60px 20px; text-align:center; color:#fff;
      }
      .fbr-pricing-contact h2 { font-size:clamp(22px,3vw,32px); font-weight:700; margin:0 0 12px; }
      .fbr-pricing-contact p  { font-size:16px; color:rgba(255,255,255,.75); margin:0 0 28px; }
      .fbr-contact-links { display:flex; gap:20px; justify-content:center; flex-wrap:wrap; }
      .fbr-contact-link {
        display:inline-flex; align-items:center; gap:8px;
        background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.2);
        color:#fff; text-decoration:none;
        padding:12px 24px; border-radius:10px; font-weight:600;
        transition:all .25s;
      }
      .fbr-contact-link:hover { background:rgba(255,255,255,.2); }

      /* responsive */
      @media(max-width:980px){
        .fbr-plans-grid { grid-template-columns:repeat(2,1fr); }
        .fbr-addons-grid { grid-template-columns:repeat(2,1fr); }
      }
      @media(max-width:580px){
        .fbr-plans-grid { grid-template-columns:1fr; }
        .fbr-addons-grid { grid-template-columns:1fr 1fr; }
      }
    </style>
  </Fragment>

