<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pricing Card - Digital Invoicing</title>
  <style>
    * {
      box-sizing: border-box;
    }

    .digital-container {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 40px 0;
    }

    .digital-card {
      width: 320px;
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
      overflow: hidden;
      text-align: center;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      margin: 10px;
      cursor: pointer;
    }

    .digital-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 18px 45px rgba(101, 191, 235, 0.4);
    }

    .digital-header {
      background: #65BFEB;
      padding: 18px;
      color: #fff;
      font-weight: bold;
      font-size: 20px;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .digital-title {
      color: #000;
      font-size: 26px;
      margin: 15px 0 10px;
      transition: color 0.3s ease;
      font-weight: bold;
    }

    .digital-features {
      background: #65BFEB;
      color: #fff;
      font-weight: 600;
      padding: 8px;
      font-size: 15px;
    }

    .digital-price {
      margin-top: 20px;
      font-size: 34px;
      font-weight: bold;
      color: #222;
      transition: transform 0.3s ease, color 0.3s ease;
    }

    .digital-price span {
      font-size: 15px;
      color: #888;
      display: block;
    }

    .digital-button {
      display: inline-block;
      background: #65BFEB;
      color: #fff;
      padding: 10px 28px;
      border-radius: 30px;
      text-decoration: none;
      font-weight: 600;
      margin: 18px 0 8px;
      transition: all 0.3s ease;
    }

    .digital-button:hover {
      background: #4aa7d6;
      box-shadow: 0 5px 15px rgba(101, 191, 235, 0.4);
    }
  </style>
</head>
<body>

<section class="digital-container">
  <div class="digital-card" id="digitalCard">
    <div class="digital-header">Pay For</div>
    <div class="digital-title" id="digitalText">Digital Invoicing</div>

    <div class="digital-features">All Features Included</div>

    <div class="digital-price" id="digitalPrice">
      <sup><b style="font-size: 12px;">PKR</b></sup> 
      <b style="font-size: 34px;">2,000/mo</b>
      <span>(incl. Sales Tax)</span>
    </div>

    <a href="/../free-trial/" class="digital-button">Buy Now</a>
  </div>
</section>

<script>
  var card = document.getElementById('digitalCard');
  var price = document.getElementById('digitalPrice');
  var text = document.getElementById('digitalText');

  card.addEventListener('mouseenter', () => {
    price.style.transform = 'scale(1.12)';
    price.style.color = '#65BFEB';
    text.style.color = '#65BFEB';
  });

  card.addEventListener('mouseleave', () => {
    price.style.transform = 'scale(1)';
    price.style.color = '#222';
    text.style.color = '#000';
  });

  card.addEventListener('click', () => {
    window.location.href = '../free-trial/index.html';
  });
</script>

