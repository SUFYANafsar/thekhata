      padding: 40px;
      background: #f4f7f6;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    table {
      width: 95%;
      max-width: 1200px;
      border-collapse: collapse;
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
      border-radius: 12px;
      overflow: hidden;
      background: #fff;
    }

    th {
      background: #2ecc71;
      color: white !important;
      padding: 20px;
      font-size: 18px;
      text-transform: uppercase;
      text-align: center;
      transition: 0.3s;
    }

    th:nth-child(2) {
      background: #27ae60;
    }

    .btn {
      min-width: 150px;
      text-align: center;
    }

    th.highlight {
      background: #1e8449;
      font-size: 20px;
    }

    td {
      padding: 14px;
      border: 1px solid #e6e6e6;
      font-size: 14px;
      color: #333;
      text-align: center;
    }

    td strong {
      font-size: 16px;
      color: #2ecc71;
    }

    /* Bold left column features */
    td:first-child {
      font-weight: bold;
      text-align: left;
    }

    .check {
      color: #2ecc71;
      font-size: 18px;
      font-weight: bold;
    }

    .cross {
      color: #e74c3c;
      font-weight: bold;
    }

    tr:nth-child(even) {
      background: #f9fdfb;
    }

    /* Hover effects */
    th:hover {
      background: rgba(46, 204, 113, 0.1);
      color: #222 !important;   /* Darker text on hover */
      font-weight: bold;
      font-size: 19px;          /* Slightly bigger */
    }

    td:hover {
      background: rgba(46, 204, 113, 0.1);
    }

    /* CTA button inside table */
    .btn {
