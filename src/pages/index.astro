---
import PageLayout from '../layouts/PageLayout.astro'
---
<PageLayout
  title="Online Accounting Software in Pakistan - Fast, Reliable, Secure"
  description="Sales, Purchases, POS, Inventory, Manufacturing, & Accounting Software in a single place. 75+ accounting, inventory, and analytical reports."
  canonical="/"
  ogImage="/wp-content/uploads/2022/01/splendid-accounts-logo.png"
  bodyClass="fbr-home"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/pages/__home__-redesign.css" />
  </Fragment>

  <!-- ======================================================
       HERO
  ====================================================== -->
  <section class="fbr-hero">
    <div class="fbr-hero-inner">
      <div class="fbr-hero-content">
        <span class="fbr-hero-badge">🇵🇰 #1 Business Software in Pakistan</span>
        <h1>Online <span>Accounting</span> &amp; Inventory Management Software</h1>
        <p class="fbr-hero-sub">Best to manage</p>
        <div class="fbr-typing-wrap">
          <span class="fbr-typing-text" id="fbr-typing"></span><span class="fbr-cursor">|</span>
        </div>
        <div class="fbr-hero-ctas">
          <a href="/free-trial/" class="fbr-btn fbr-btn-primary">🚀 14 Days Free Trial</a>
          <a href="/contact/" class="fbr-btn fbr-btn-outline" style="color:#fff;border-color:rgba(255,255,255,.4);">Get a Demo</a>
        </div>
        <div class="fbr-app-badges">
          <a href="https://play.google.com/store/apps/details?id=com.fbrsoftware.invoicing" target="_blank" rel="noopener">
            <img src="/wp-content/uploads/2021/08/play-store.png" alt="Google Play Store" />
          </a>
          <a href="https://apps.apple.com/us/app/fbr-software/id14888" target="_blank" rel="noopener">
            <img src="/wp-content/uploads/2021/08/apple-store.png" alt="Apple App Store" />
          </a>
        </div>
      </div>
      <div class="fbr-hero-image">
        <img
          src="/wp-content/uploads/2022/01/new-main-dasboard.jpg"
          alt="FBR Software Dashboard"
          width="689" height="590"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- ======================================================
       STATS BAR
  ====================================================== -->
  <div class="fbr-stats">
    <div class="fbr-stats-inner">
      <div class="fbr-stat-item">
        <div class="fbr-stat-num">5,000+</div>
        <div class="fbr-stat-label">Active Businesses</div>
      </div>
      <div class="fbr-stat-item">
        <div class="fbr-stat-num">14</div>
        <div class="fbr-stat-label">Days Free Trial</div>
      </div>
      <div class="fbr-stat-item">
        <div class="fbr-stat-num">75+</div>
        <div class="fbr-stat-label">Business Reports</div>
      </div>
      <div class="fbr-stat-item">
        <div class="fbr-stat-num">90%</div>
        <div class="fbr-stat-label">Auto Accounting Entries</div>
      </div>
    </div>
  </div>

  <!-- ======================================================
       FEATURES
  ====================================================== -->
  <section class="fbr-section fbr-features">
    <div class="fbr-container">
      <span class="fbr-badge">Why Choose Us</span>
      <h2 class="fbr-section-title">Best Cloud-based Accounting Software<br />for Small Businesses in Pakistan</h2>
      <p class="fbr-section-sub">Speed-Up your Invoicing, Accounting, Inventory and Reporting. Boost your business with our go-to platform.</p>
      <div class="fbr-features-grid">
        <div class="fbr-feature-card">
          <div class="fbr-feature-icon" style="background:#e8f5ff;">
            <img src="/wp-content/uploads/2021/08/Seamless-Invoicing.png" alt="Invoicing" style="width:48px;height:48px;object-fit:contain;" />
          </div>
          <h3>FBR Invoicing</h3>
          <p>Create and send quotations and invoices in a single click. Manage your receivables in a better way.</p>
        </div>
        <div class="fbr-feature-card">
          <div class="fbr-feature-icon" style="background:#e8fff2;">
            <img src="/wp-content/uploads/2021/08/Stress-Free.png" alt="Accounting" style="width:48px;height:48px;object-fit:contain;" />
          </div>
          <h3>Stress-Free Accounting</h3>
          <p>No accounting expertise required. Automatically posts more than 90% of accounting entries behind the scenes.</p>
        </div>
        <div class="fbr-feature-card">
          <div class="fbr-feature-icon" style="background:#fff8e8;">
            <img src="/wp-content/uploads/2021/08/Up-to-Date-1.png" alt="Inventory" style="width:48px;height:48px;object-fit:contain;" />
          </div>
          <h3>Up-to-Date Inventory</h3>
          <p>Never run out of stock again. Monitors your inventory levels and tells you when and what to reorder.</p>
        </div>
        <div class="fbr-feature-card">
          <div class="fbr-feature-icon" style="background:#f0e8ff;">
            <img src="/wp-content/uploads/2021/08/Comprehensive-Reporting-1.png" alt="Reporting" style="width:48px;height:48px;object-fit:contain;" />
          </div>
          <h3>Comprehensive Reporting</h3>
          <p>Dozens of reports will help you understand the health of your business and make better decisions.</p>
