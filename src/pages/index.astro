  <!-- Typing animation script -->
  <script is:inline>

    (function() {
      var strings = ['Inventory','Accounting','Multiple Warehouses','Invoices','Customers','Receivables','Vendors','Payables','Retail Stores','Garments & Fashion','Shoe Stores','Electronics & Appliances','Book Stores','Restaurants & Bakers','Distribution & Wholesale','Computers'];
      var el = document.getElementById('fbr-typing');
      if (!el) return;
      var i = 0, j = 0, deleting = false;
      function tick() {
        var current = strings[i % strings.length];
        el.textContent = deleting ? current.substring(0, j--) : current.substring(0, j++);
        var speed = deleting ? 50 : 100;
        if (!deleting && j === current.length + 1) { deleting = true; speed = 1200; }
        else if (deleting && j === 0) { deleting = false; i++; speed = 400; }
        setTimeout(tick, speed);
      }
      tick();
    })();
  </script>
