---
import PageLayout from '../../layouts/PageLayout.astro'
---
<PageLayout
  title="Search – Splendid Accounts"
  description="Search the Splendid Accounts knowledge base and blog."
  canonical="/search/"
  ogImage=""
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </Fragment>

  <div id="et-main-area">
    <div id="main-content">
      <div class="et_builder_inner_content et_pb_gutters3">
        <div class="et_pb_section et_pb_section_0 et_section_regular" style="padding:60px 0 40px">
          <div class="et_pb_row et_pb_row_0">
            <div class="et_pb_column et_pb_column_4_4">
              <h1 style="text-align:center;margin-bottom:30px">Search</h1>
              <div id="search" style="max-width:800px;margin:0 auto"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>

<script is:inline>
  window.addEventListener('DOMContentLoaded', function () {
    var s = document.createElement('script')
    s.src = '/pagefind/pagefind-ui.js'
    s.onload = function () {
      new PagefindUI({ element: '#search', showImages: false })
    }
    document.head.appendChild(s)
  })
</script>
