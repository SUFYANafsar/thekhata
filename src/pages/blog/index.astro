const categories = ['All', 'Retail', 'Accounting', 'Wholesale & Distribution']
---
<PageLayout
  title="Accounting & Inventory Software Blog Pakistan | FBR Software"
  description="Expert tips on accounting software, FBR e-invoicing, inventory management & business growth for Pakistani businesses. Stay updated with FBR Software blog."
  canonical="/blog/"
  bodyClass="fbr-home"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/pages/__home__-redesign.css" />
    <style>
      /* ── Blog page styles ── */
      .fbr-blog-hero {
        background: linear-gradient(135deg,#0d1b35 0%,#1a3461 50%,#1565a8 100%);
        padding: 80px 20px 60px;
        text-align: center;
        color: #fff;
      }
      .fbr-blog-hero h1 { font-size:clamp(28px,4vw,48px); font-weight:800; margin:0 0 14px; color:#fff !important; }
      .fbr-blog-hero p  { font-size:17px; color:rgba(255,255,255,.75); max-width:560px; margin:0 auto; }

      /* category filter */
      .fbr-blog-filters {
        display: flex; gap:10px; flex-wrap:wrap;
        justify-content:center;
        padding: 36px 20px 0;
        max-width: 1200px; margin: 0 auto;
      }
      .fbr-filter-btn {
        padding: 8px 20px; border-radius: 20px;
        font-size: 13px; font-weight: 600;
        border: 2px solid #e0e8f0;
        background: #fff; color: #5a6a80;
        cursor: pointer; transition: all .2s;
      }
      .fbr-filter-btn:hover,
      .fbr-filter-btn.active {
        background: #2ea3f2; border-color: #2ea3f2; color: #fff;
      }

      /* grid */
      .fbr-blog-grid-wrap {
        max-width: 1200px; margin: 0 auto;
        padding: 36px 20px 60px;
      }
      .fbr-blog-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 28px;
      }
      .fbr-blog-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(26,43,74,.07);
        display: flex; flex-direction: column;
        transition: transform .25s, box-shadow .25s;
        border: 1px solid #e8edf5;
      }
      .fbr-blog-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 16px 48px rgba(46,163,242,.15);
        border-color: #2ea3f2;
      }
      .fbr-blog-card-thumb {
        background: linear-gradient(135deg,#1a3461,#1565a8);
        height: 140px;
        display: flex; align-items: center; justify-content: center;
        font-size: 56px;
      }
      .fbr-blog-card-body { padding: 22px 24px; flex: 1; display: flex; flex-direction: column; }
      .fbr-blog-card-meta {
        display: flex; align-items: center; gap: 10px;
        margin-bottom: 12px; flex-wrap: wrap;
      }
      .fbr-blog-cat {
        background: #e8f5ff; color: #1a78c2;
        font-size: 11px; font-weight: 700;
        padding: 3px 10px; border-radius: 10px;
        text-decoration: none; text-transform: uppercase; letter-spacing: .05em;
        transition: background .2s;
      }
      .fbr-blog-cat:hover { background: #2ea3f2; color: #fff; }
      .fbr-blog-date { font-size: 12px; color: #8090a8; }
      .fbr-blog-card h2 {
        font-size: 16px; font-weight: 700; color: #1a2b4a;
        margin: 0 0 10px; line-height: 1.4;
      }
      .fbr-blog-card h2 a { text-decoration: none; color: inherit; }
      .fbr-blog-card h2 a:hover { color: #2ea3f2; }
      .fbr-blog-excerpt {
        font-size: 13px; color: #5a6a80; line-height: 1.65;
        flex: 1; margin-bottom: 18px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .fbr-blog-card-footer {
        display: flex; align-items: center; justify-content: space-between;
        border-top: 1px solid #f0f4f8; padding-top: 14px;
        margin-top: auto;
      }
      .fbr-blog-author { font-size: 12px; color: #8090a8; }
      .fbr-blog-read-more {
        font-size: 13px; font-weight: 600; color: #2ea3f2;
        text-decoration: none; display: flex; align-items: center; gap: 4px;
      }
      .fbr-blog-read-more:hover { color: #1a78c2; }

      /* pagination */
      .fbr-blog-pagination {
        display: flex; justify-content: center; gap: 10px;
        padding: 0 20px 60px;
      }
      .fbr-page-btn {
        padding: 10px 20px; border-radius: 8px;
        font-size: 14px; font-weight: 600;
        background: #fff; color: #1a2b4a;
        border: 2px solid #e0e8f0;
        text-decoration: none; transition: all .2s;
      }
      .fbr-page-btn:hover, .fbr-page-btn.active {
        background: #2ea3f2; border-color: #2ea3f2; color: #fff;
      }

      /* hidden cards */
      .fbr-blog-card[data-hidden="true"] { display: none; }

      @media(max-width:980px){ .fbr-blog-grid { grid-template-columns: repeat(2,1fr); } }
      @media(max-width:580px){ .fbr-blog-grid { grid-template-columns: 1fr; } }
    </style>
  </Fragment>

  <!-- HERO -->
  <div class="fbr-blog-hero">
    <span class="fbr-hero-badge">Knowledge Base</span>
    <h1>FBR Software Blog</h1>
    <p>Expert insights on accounting, inventory, FBR compliance, and growing your business in Pakistan.</p>
  </div>

  <!-- FILTERS -->
  <div class="fbr-blog-filters">
    {categories.map((cat) => (
      <button class={`fbr-filter-btn${cat === 'All' ? ' active' : ''}`} data-cat={cat}>
        {cat}
      </button>
    ))}
  </div>

  <!-- BLOG GRID -->
  <div class="fbr-blog-grid-wrap">
    <div class="fbr-blog-grid" id="fbr-blog-grid">
      {posts.map((post) => (
        <article class="fbr-blog-card" data-category={post.category}>
          <div class="fbr-blog-card-thumb">{post.icon}</div>
          <div class="fbr-blog-card-body">
            <div class="fbr-blog-card-meta">
              <a href={post.categorySlug} class="fbr-blog-cat">{post.category}</a>
              <span class="fbr-blog-date">📅 {post.date}</span>
            </div>
            <h2><a href={post.slug}>{post.title}</a></h2>
            <p class="fbr-blog-excerpt">{post.excerpt}</p>
            <div class="fbr-blog-card-footer">
              <span class="fbr-blog-author">✍️ {post.author}</span>
              <a href={post.slug} class="fbr-blog-read-more">Read More →</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- PAGINATION -->
  <div class="fbr-blog-pagination">
    <span class="fbr-page-btn active">1</span>
    <a href="/blog/page/2/" class="fbr-page-btn">2</a>
    <a href="/blog/page/2/" class="fbr-page-btn">Older →</a>
  </div>

  <!-- Filter Script -->
  <script is:inline>
    var btns = document.querySelectorAll('.fbr-filter-btn');
    var cards = document.querySelectorAll('.fbr-blog-card');
    btns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var cat = this.dataset.cat;
        btns.forEach(function(b){ b.classList.remove('active'); });
        this.classList.add('active');
        cards.forEach(function(card) {
          if (cat === 'All' || card.dataset.category === cat) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>
</PageLayout>
