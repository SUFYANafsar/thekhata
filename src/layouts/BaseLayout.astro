---
import WAChat from '../components/WAChat.astro'
import SplendidPopup from '../components/SplendidPopup.astro'
interface Props {
  title: string
  description: string
  canonical?: string
  ogType?: 'website' | 'article'
  ogImage?: string
  articlePublished?: string
  articleModified?: string
  schemaJson?: string
  bodyClass?: string
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  ogImage = '/wp-content/uploads/2022/01/splendid-accounts-logo.png',
  articlePublished,
  articleModified,
  schemaJson,
  bodyClass = '',
} = Astro.props

const canonicalUrl = canonical
  ? `https://SpartanTech.org${canonical}`
  : `https://SpartanTech.org${Astro.url.pathname}`
---

<!doctype html>
<html lang="en-US">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:locale" content="en_US" />
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Spartan Accounts" />
  <meta property="og:image" content={`https://SpartanTech.org${ogImage}`} />
  {articlePublished && <meta property="article:published_time" content={articlePublished} />}
  {articleModified && <meta property="article:modified_time" content={articleModified} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@splendidaccoun1" />

  <!-- Schema JSON-LD -->
  {schemaJson && <script type="application/ld+json" set:html={schemaJson} />}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" />

  <!-- Divi / LiteSpeed CSS bundles (paths unchanged from source) -->
  <link rel="stylesheet" href="/wp-content/litespeed/css/7a011636439558ba9580cc64db04deaa8dae.css" media="all" />
  <link rel="stylesheet" href="/wp-content/litespeed/css/c18ea31df49223d5de247c0df500f6ec5c06.css" media="all" />
  <link rel="stylesheet" href="/wp-content/litespeed/css/b9d9d9a406aa6f47c9a27e8a3c6d5a1a2d9f.css" media="all" />
  <link rel="stylesheet" href="/wp-content/litespeed/css/9cff59040e2374359419b03ca33c005fce37.css" media="all" />
  <link rel="stylesheet" href="/wp-content/litespeed/css/6152c48625030a20b23c0bb1cf43646ff9f3.css" media="all" />
  <link rel="stylesheet" href="/wp-content/litespeed/css/4778229086aebe11410db0bab4d6792f1ce1.css" media="all" />
  <link rel="stylesheet" href="/wp-content/litespeed/css/99c1041cf447716b7d5423acba940749055f.css" media="all" />
  <link rel="stylesheet" href="/wp-content/litespeed/css/0145b8cfed2ed379eac432b3fb16aeeb4873.css" media="all" />
  <link rel="stylesheet" href="/wp-content/litespeed/css/379c645cf787dbec6000c2fd8090ded710b7.css" media="all" />

  <!-- Divi core + page TB-132 (post 11): WP inlined these + et-cache; LiteSpeed bundles alone are not enough for layout -->
  <link rel="stylesheet" href="/wp-content/et-cache/11/divi-wp-critical-combined.css" media="all" />
  <link rel="stylesheet" href="/wp-content/et-cache/11/et-divi-dynamic-tb-132-113705.css" media="all" />
  <link rel="stylesheet" href="/wp-content/et-cache/11/et-divi-dynamic-tb-132-11-late3705.css" media="all" />
  <link rel="stylesheet" href="/wp-content/et-cache/11/et-core-unified-tb-132-deferred-11.min0fe6.css" media="all" />

  <!-- Google Tag Manager -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=UA-38116496-9"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'UA-38116496-9');
    gtag('config', 'AW-869196053');
  </script>

  <!-- jQuery loaded in <head> so inline Divi scripts in the body can call it -->
  <script is:inline src="/wp-includes/js/jquery/jquery.minf43b.js"></script>
  <script is:inline src="/wp-content/litespeed/js/76eb09d2354632ba6185dc7095b9e22f1a37.js"></script>
  <!-- Restore $ alias — WP jQuery runs noConflict() which removes $, but page scripts expect it -->
  <script is:inline>window.$ = window.jQuery;</script>

  <slot name="head" />
</head>

<body class={`wp-singular et_pb_button_helper_class et_fixed_nav et_show_nav et_primary_nav_dropdown_animation_fade et_secondary_nav_dropdown_animation_fade et_header_style_left et_cover_background et_pb_gutter et_pb_gutters3 et_pb_pagebuilder_layout et_divi_theme et-db et-tb-has-template et-tb-has-footer mkb-desktop ${bodyClass}`}>
  <script is:inline>
    if (location.protocol === 'file:') {
      console.warn(
        '[Splendid Astro] file:// breaks root-relative URLs (/wp-content/, /wp-includes/). After build, use npm run preview or npx serve dist — do not open dist/index.html directly.'
      )
    }
  </script>
  <script is:inline>
    // #region agent log
    queueMicrotask(function () {
      var hrefs = []
      document.querySelectorAll('link[rel="stylesheet"]').forEach(function (l) {
        hrefs.push(l.getAttribute('href') || '')
      })
      var et = hrefs.filter(function (h) {
        return h.indexOf('et-cache/11') !== -1
      })
      var crit = hrefs.some(function (h) {
        return h.indexOf('divi-wp-critical-combined') !== -1
      })
      fetch('http://127.0.0.1:7402/ingest/ad11af42-c7d7-4139-b524-ff8682f58045', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Debug-Session-Id': 'a2c0d5' },
        body: JSON.stringify({
          sessionId: 'a2c0d5',
          hypothesisId: 'H1',
          location: 'BaseLayout.astro:body',
          message: 'stylesheet hrefs after parse',
          data: { total: hrefs.length, etCache11: et.length, hasCritical: crit, etSample: et.slice(0, 6) },
          timestamp: Date.now(),
        }),
      }).catch(function () {})
    })
    // #endregion
  </script>

  <div id="page-container">
    <div id="et-boc" class="et-boc">
      <slot />
    </div>
  </div>

  <!-- WP/Divi/Minerva globals normally injected by PHP wp_localize_script -->
  <script is:inline>
