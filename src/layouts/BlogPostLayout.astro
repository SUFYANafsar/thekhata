---
import BaseLayout from './BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  description: string
  canonical?: string
  ogImage?: string
  published?: string
  modified?: string
  schemaJson?: string
}

const props = Astro.props
---

<BaseLayout
  {...props}
  ogType="article"
  articlePublished={props.published}
  articleModified={props.modified}
  bodyClass="single single-post et_right_sidebar"
>
  <Header />
  <div id="et-main-area">
    <div id="main-content" data-pagefind-body>
      <slot />
    </div>
  </div>
  <Footer />
</BaseLayout>
