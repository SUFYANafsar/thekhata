---
import BaseLayout from './BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  description: string
  canonical?: string
  ogType?: 'website' | 'article'
  ogImage?: string
  articleModified?: string
  schemaJson?: string
  bodyClass?: string
}

const { bodyClass = 'et_no_sidebar', ...props } = Astro.props
---

<BaseLayout {...props} bodyClass={bodyClass}>
  <Fragment slot="head">
    <slot name="head" />
  </Fragment>
  <Header />
  <slot />
  <Footer />
</BaseLayout>
